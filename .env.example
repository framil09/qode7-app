# ========================================
# CONFIGURAÇÃO DE EMAIL (GMAIL OU OUTRO SMTP)
# ========================================
# Para usar Gmail em produção:
# 1. Crie uma senha de aplicativo: https://myaccount.google.com/apppasswords
# 2. Preencha as variáveis abaixo:

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app-do-gmail

# Configuração da Empresa (para onde vão as notificações de novas reuniões)
COMPANY_EMAIL=comercial@qode7.com

# ========================================
# GOOGLE CALENDAR API (INTEGRAÇÃO OAUTH2)
# ========================================
# 1. Crie um projeto no Google Cloud Console: https://console.cloud.google.com/
# 2. Habilite a "Google Calendar API"
# 3. Vá em "Tela de consentimento OAuth" e configure como Externo
# 4. Vá em "Credenciais" > "Criar credenciais" > "ID do cliente OAuth"
# 5. Tipo de aplicativo: "Aplicativo da Web"
# 6. Adicione URIs de redirecionamento autorizados: http://localhost:3000/api/auth/google/callback
# 7. Obtenha o CLIENT_ID e CLIENT_SECRET
# 8. Obtenha o REFRESH_TOKEN (use ferramentas como o OAuth 2.0 Playground)

GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REFRESH_TOKEN=seu_refresh_token
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ========================================
# CONFIGURAÇÕES DO SERVIDOR
# ========================================
NODE_ENV=development
PORT=3000

# Analytics (opcional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
